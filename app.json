{
  "expo": {
    "name": "GlowUp",
    "slug": "glowup",
    "version": "1.0.0",
    "scheme": "glowup",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E07856"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.glowup.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "SKAdNetworkItems": [
          {
            "SKAdNetworkIdentifier": "v9wttpbfk9.skadnetwork"
          },
          {
            "SKAdNetworkIdentifier": "n38lu8286q.skadnetwork"
          }
        ]
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "com.glowup.skincare",
      "adaptiveIcon": {
        "backgroundColor": "#E07856",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "com.google.android.gms.permission.AD_ID"
      ],
      "targetSdkVersion": 36,
      "compileSdkVersion": 36
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      ["@react-native-firebase/crashlytics", { "android": { "enabledInDevMode": true } }],
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "GlowUp needs camera access to scan your skin."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "GlowUp needs photo library access to upload a photo for skin analysis."
        }
      ],
      [
        "react-native-fbsdk-next",
        {
          "appID": "1631246151315033",
          "clientToken": "f8cf49e368b4582cc75f2c5e228e916e",
          "displayName": "GlowUp",
          "scheme": "fb1631246151315033",
          "advertiserIDCollectionEnabled": true,
          "autoLogAppEventsEnabled": true,
          "isAutoInitEnabled": true
        }
      ],
      "expo-tracking-transparency",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E07856"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a0e9d65c-8301-4920-81a9-cf34245c854b"
      }
    },
    "owner": "rahsai374",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a0e9d65c-8301-4920-81a9-cf34245c854b"
    }
  }
}
